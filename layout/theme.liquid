<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    {% # Inlined CSS Variables %}
    {% render 'css-variables' %}

    {% comment %}
      Font preloading:
      1. Preconnect to font CDN for faster connection
      2. Preload only the critical font variant (base weight)
      3. Additional variants load on-demand via @font-face
    {% endcomment %}
    {% comment %} Preconnect to Google Fonts for menopause advertorial pages {% endcomment %}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    {% unless settings.type_primary_font.system? %}
      <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>

      {% comment %} Preload the base font variant for initial page render {% endcomment %}
      {{ settings.type_primary_font | font_url | preload_tag: as: 'font', crossorigin: 'anonymous' }}
    {% endunless %}

    {% # Load and preload the critical CSS %}
    {{ 'critical.css' | asset_url | stylesheet_tag: preload: true }}

    {% # Social, title, etc. %}
    {% render 'meta-tags' %}

    {% # Analytics & Heatmaps %}
    {% render 'contentsquare-tracking' %}

    {{ content_for_header }}
  </head>

  <body>
    {% comment %}
      Expose customer data for Meta CAPI enhanced matching (EMQ 8+).
      Email and phone are passed unhashed here; the tracking script
      hashes them client-side via SHA-256 before sending.
    {% endcomment %}
    {% if customer %}
      <script>
        window.__shopifyCustomerId = {{ customer.id | json }};
        {% if customer.email %}window.__shopifyCustomerEmail = {{ customer.email | json }};{% endif %}
        {% if customer.phone %}window.__shopifyCustomerPhone = {{ customer.phone | json }};{% endif %}
      </script>
    {% endif %}

    {% sections 'header-group' %}

    {{ content_for_layout }}

    {% sections 'footer-group' %}
  </body>
</html>
