<script>
  (function() {
    if (window.__metaCtaTrackingInit) return;
    window.__metaCtaTrackingInit = true;

    document.addEventListener('click', function(e) {
      var cta = e.target.closest('[data-meta-event]');
      if (!cta) return;

      var href = cta.getAttribute('href');
      if (!href) return;

      var eventName = cta.getAttribute('data-meta-event') || 'Lead';
      var payload = {
        content_name: cta.getAttribute('data-meta-product-name') || '',
        content_ids: [cta.getAttribute('data-meta-content-id') || ''],
        content_type: 'product',
        value: parseFloat(cta.getAttribute('data-meta-value')) || 0,
        currency: cta.getAttribute('data-meta-currency') || 'IDR',
        custom_data: {
          category: cta.getAttribute('data-meta-category') || 'Blog to Store Conversion',
          position: cta.getAttribute('data-meta-cta-position') || 'unknown'
        }
      };

      // Helper function to fire event
      var fireEvent = function() {
        if (window.Shopify && window.Shopify.analytics && window.Shopify.analytics.publish) {
          Shopify.analytics.publish('cta_lead_event', payload);
        }
      };

      // OPTIMIZATION: Check if user is trying to open in a new tab
      var isNewTab = e.ctrlKey || e.metaKey || e.shiftKey || e.button === 1 || cta.getAttribute('target') === '_blank';

      if (isNewTab) {
        // Fire event and let the browser handle the new tab natively
        fireEvent();
        return; 
      }

      // If opening in the same tab, prevent default, fire event, and delay redirect
      e.preventDefault();
      fireEvent();

      // Ensure UTM parameters are strictly enforced if needed, then redirect
      setTimeout(function() {
        window.location.href = href;
      }, 150);
    });
  })();
</script>