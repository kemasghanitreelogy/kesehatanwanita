{% comment %}
  Article structured data (JSON-LD) for advertorial V2 pages.
  Improves SEO rich results and social sharing. Follows schema.org/Article.
  Usage: {% render 'adv2-structured-data', headline: 'Title', author: 'Name', description: 'Desc', image: image_object %}
{% endcomment %}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "{{ canonical_url }}"
  },
  "headline": {{ headline | default: page_title | json }},
  "description": {{ description | default: page_description | json }},
  {% if image %}
  "image": {
    "@type": "ImageObject",
    "url": "https:{{ image | image_url: width: 1200 }}",
    "width": 1200,
    "height": 630
  },
  {% endif %}
  "author": {
    "@type": "Person",
    "name": {{ author | default: 'Kusumawardan' | json }}
  },
  "publisher": {
    "@type": "Organization",
    "name": {{ shop.name | json }},
    "url": {{ shop.url | json }}
  },
  "datePublished": {{ page.published_at | default: 'now' | date: '%Y-%m-%dT%H:%M:%S%z' | json }},
  "dateModified": {{ page.updated_at | default: 'now' | date: '%Y-%m-%dT%H:%M:%S%z' | json }},
  "inLanguage": "id-ID",
  "about": {
    "@type": "MedicalCondition",
    "name": "Menopause"
  }
}
</script>
