{% comment %}
  Shared styles for the V7 ID Cluster advertorial.
  All rules scoped under .v7-cluster-page so they do not leak.

  Fonts intentionally mirror the advertorial-v2 pages (/pages/menopause):
  system font stack, no webfont load. If a designer needs the editorial
  serif look again, re-add the Google Fonts link and swap font-family
  back to 'Source Serif 4', Georgia, serif.
{% endcomment %}

{% stylesheet %}
  body:has(.v7-cluster-page) {
    background: #fafaf7;
    margin: 0;
  }

  .v7-cluster-page {
    max-width: 680px;
    margin: 0 auto;
    background: #fff;
    box-shadow: 0 0 40px rgba(0, 0, 0, 0.04);
    font-family: -apple-system
    , 'Segoe UI'
    , Roboto
    , Helvetica
    , Arial
    , sans-serif;
    color: #1a1a1a;
    line-height: 1.82;
    -webkit-font-smoothing: antialiased;
    -webkit-text-size-adjust: 100%;
  }
  .v7-cluster-page,
  .v7-cluster-page * {
    box-sizing: border-box;
  }
  .v7-cluster-page p,
  .v7-cluster-page h1,
  .v7-cluster-page blockquote,
  .v7-cluster-page div {
    margin: 0;
  }


  /*
   Theme-level rules put .shopify-section into a flex+stretch container and
   force every direct child to width:100% + 20px side padding. Left unchecked
   the stretched width + our 24px side margins make blockquote.dm,
   blockquote.testimonial, and .img-placeholder overflow the 680px page.
   Fix by restoring block flow and width:auto. We intentionally DO NOT reset
   padding-left/right here — our per-element padding rules below (.article-
   meta, h1, .deck, .byline, p.body, .lead, etc.) already override the theme
   because they are more specific, and zeroing padding here would win on
   specificity against element selectors like h1 and break their 24px inset.
*/
  .v7-cluster-page > .shopify-section {
    display: block;
    width: 100%;
    padding: 0;
  }
  .v7-cluster-page > .shopify-section > * {
    width: auto;
    max-width: none;
  }

  .v7-cluster-page .version-banner {
    background: #0d3b2e;
    color: #fff;
    padding: 10px 20px;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.5px;
  }
  .v7-cluster-page .version-banner strong {
    color: #c9a96e;
  }

  .v7-cluster-page .masthead {
    padding: 22px 24px 18px;
    border-bottom: 1px solid #eee;
  }
  .v7-cluster-page .masthead .pub {
    font-size: 11px;
    letter-spacing: 1.6px;
    text-transform: uppercase;
    color: #888;
    margin-bottom: 4px;
  }
  .v7-cluster-page .masthead .pub-name {
    font-size: 22px;
    font-weight: 700;
    color: #0d3b2e;
    letter-spacing: -0.2px;
  }

  .v7-cluster-page .article-meta {
    padding: 28px 24px 0;
    font-size: 12px;
    color: #8a8a8a;
    text-transform: uppercase;
    letter-spacing: 1.3px;
    font-weight: 500;
  }

  .v7-cluster-page h1 {
    font-size: 30px;
    font-weight: 700;
    line-height: 1.22;
    color: #111;
    padding: 16px 24px 14px;
    letter-spacing: -0.5px;
  }
  @media (max-width: 480px) {
    .v7-cluster-page h1 {
      font-size: 25px;
      line-height: 1.28;
    }
  }

  .v7-cluster-page .deck {
    font-size: 18px;
    color: #555;
    line-height: 1.5;
    padding: 0 24px 18px;
    font-weight: 400;
    font-style: italic;
  }

  .v7-cluster-page .byline {
    font-size: 13px;
    color: #888;
    padding: 0 24px 24px;
    letter-spacing: 0.2px;
  }
  .v7-cluster-page .byline strong {
    color: #333;
    font-weight: 600;
  }

  .v7-cluster-page .hero-img {
    width: 100%;
    height: auto;
    display: block;
    margin-bottom: 28px;
  }

  .v7-cluster-page p.body {
    font-size: 18px;
    color: #222;
    line-height: 1.72;
    padding: 0 24px 22px;
  }
  .v7-cluster-page p.body strong {
    color: #0d3b2e;
    font-weight: 700;
  }

  .v7-cluster-page .lead {
    font-size: 22px;
    font-weight: 700;
    line-height: 1.38;
    color: #0d3b2e;
    padding: 8px 24px 22px;
    letter-spacing: -0.2px;
  }
  @media (max-width: 480px) {
    .v7-cluster-page .lead {
      font-size: 19px;
    }
  }

  .v7-cluster-page .cluster-intro {
    font-size: 19px;
    color: #222;
    line-height: 1.6;
    padding: 10px 24px 20px;
    font-weight: 500;
  }
  .v7-cluster-page .cluster-list {
    padding: 24px 24px 10px;
    background: #f4f3ee;
    border-left: 3px solid #0d3b2e;
    border-radius: 0 6px 6px 0;
  }
  .v7-cluster-page .cluster-list-container {
    padding: 0 24px 28px;
  }
  .v7-cluster-page .cluster-item {
    display: flex;
    gap: 16px;
    padding-bottom: 18px;
    margin-bottom: 18px;
    border-bottom: 1px solid #e3e2dc;
  }
  .v7-cluster-page .cluster-item:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 6px;
  }
  .v7-cluster-page .cluster-num {
    flex-shrink: 0;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background: #0d3b2e;
    color: #fff;
    font-size: 14px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 2px;
  }
  .v7-cluster-page .cluster-text {
    font-size: 17px;
    line-height: 1.58;
    color: #2a2a2a;
  }
  .v7-cluster-page .cluster-text strong {
    display: block;
    color: #0d3b2e;
    font-weight: 700;
    margin-bottom: 4px;
    font-size: 17px;
  }
  .v7-cluster-page .cluster-punchline {
    font-size: 19px;
    font-weight: 600;
    color: #0d3b2e;
    line-height: 1.5;
    padding: 0 24px 22px;
  }

  .v7-cluster-page blockquote.dm {
    background: #f4f3ee;
    border-left: 3px solid #0d3b2e;
    margin: 4px 24px 28px;
    padding: 18px 22px;
    font-size: 17px;
    font-style: italic;
    color: #2a2a2a;
    line-height: 1.6;
    border-radius: 0 6px 6px 0;
  }
  .v7-cluster-page blockquote.dm .attribution {
    display: block;
    margin-top: 10px;
    font-style: normal;
    font-size: 13px;
    color: #777;
    font-weight: 500;
  }

  .v7-cluster-page blockquote.testimonial {
    margin: 4px 24px 28px;
    padding: 0 0 0 18px;
    border-left: 3px solid #c9a96e;
    font-size: 17px;
    font-style: italic;
    color: #333;
    line-height: 1.56;
  }
  .v7-cluster-page blockquote.testimonial .attribution {
    display: block;
    margin-top: 10px;
    font-style: normal;
    font-size: 12px;
    color: #888;
    font-weight: 500;
    letter-spacing: 0.3px;
    text-transform: uppercase;
  }

  .v7-cluster-page .section-img {
    width: 100%;
    height: auto;
    display: block;
    margin: 0 0 24px;
    border-radius: 4px;
  }
  .v7-cluster-page .img-placeholder {
    background: #f0efe9;
    border: 1px dashed #bbb;
    margin: 0 24px 24px;
    padding: 60px 20px;
    text-align: center;
    font-size: 13px;
    color: #888;
    border-radius: 4px;
    line-height: 1.5;
  }
  .v7-cluster-page .img-placeholder strong {
    color: #555;
    display: block;
    margin-bottom: 4px;
  }

  /* ===== OFFER CARD — mirrors .adv-offer-card on /pages/menopause ===== */
  @keyframes v7-vibrate {
    0% {
      transform: rotate(0deg);
    }
    10% {
      transform: rotate(-12deg);
    }
    20% {
      transform: rotate(12deg);
    }
    30% {
      transform: rotate(-10deg);
    }
    40% {
      transform: rotate(10deg);
    }
    50% {
      transform: rotate(-6deg);
    }
    60% {
      transform: rotate(6deg);
    }
    70% {
      transform: rotate(-2deg);
    }
    80% {
      transform: rotate(2deg);
    }
    90% {
      transform: rotate(0deg);
    }
    100% {
      transform: rotate(0deg);
    }
  }

  .v7-cluster-page .offer-wrap {
    padding: 0;
  }
  .v7-cluster-page .offer-card {
    margin: 32px 16px 0;
    border: 2px solid #2d6a4f;
    border-radius: 14px;
    overflow: hidden;
    background: #fff;
    box-shadow: 0 6px 28px rgba(45, 106, 79, 0.10);
  }
  .v7-cluster-page .offer-urgency {
    background: #b91c1c;
    color: #fff;
    text-align: center;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.8px;
    padding: 10px 16px;
    text-transform: uppercase;
    border-bottom: none;
  }
  .v7-cluster-page .offer-urgency .urg-icon {
    display: inline-block;
    animation: v7-vibrate 0.6s ease-in-out infinite;
    transform-origin: center center;
  }

  .v7-cluster-page .offer-card .img-placeholder,
  .v7-cluster-page .offer-card .product-img {
    margin: 0;
    border-radius: 0;
    border: none;
    width: 100%;
  }
  .v7-cluster-page .offer-card .product-img {
    display: block;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    background: #f5f5f0;
    height: auto;
  }
  .v7-cluster-page .offer-card .img-placeholder {
    padding: 50px 20px;
  }

  .v7-cluster-page .offer-body {
    padding: 24px 20px 22px;
    text-align: center;
  }
  .v7-cluster-page .offer-label {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: #2d6a4f;
    font-weight: 600;
    margin-bottom: 6px;
  }
  .v7-cluster-page .offer-title {
    font-size: 20px;
    font-weight: 700;
    color: #1a1a1a;
    line-height: 1.3;
    margin-bottom: 4px;
    letter-spacing: 0;
  }
  .v7-cluster-page .offer-contents {
    font-size: 14px;
    color: #666;
    margin-bottom: 18px;
    line-height: 1.45;
  }
  .v7-cluster-page .offer-contents .offer-product-name {
    margin-bottom: 10px;
  }
  .v7-cluster-page .offer-contents .offer-benefits {
    list-style: none;
    margin: 0;
    padding: 0;
    display: inline-flex;
    flex-direction: column;
    gap: 8px;
    text-align: left;
  }
  .v7-cluster-page .offer-contents .offer-benefit {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 14px;
    color: #1a1a1a;
    line-height: 1.4;
  }
  .v7-cluster-page .offer-contents .benefit-icon {
    flex: 0 0 20px;
    width: 20px;
    height: 20px;
  }
  .v7-cluster-page .price-stack {
    margin-bottom: 18px;
    text-align: center;
  }
  .v7-cluster-page .price-old {
    font-size: 15px;
    color: #aaa;
    text-decoration: line-through;
    margin-right: 10px;
    vertical-align: middle;
  }
  .v7-cluster-page .price-new {
    font-size: 30px;
    font-weight: 800;
    color: #1a1a1a;
    letter-spacing: -0.5px;
    display: inline;
    vertical-align: middle;
  }
  .v7-cluster-page .price-saving {
    display: inline-block;
    background: #b91c1c;
    color: #fff;
    font-size: 13px;
    font-weight: 700;
    padding: 4px 12px;
    border-radius: 4px;
    letter-spacing: 0.2px;
    margin-left: 8px;
    margin-top: 0;
    vertical-align: middle;
    text-decoration: none;
    font-family: inherit;
  }
  .v7-cluster-page .price-discount-pct {
    display: block;
    margin-top: 4px;
    font-size: 12px;
    color: #2d6a4f;
    font-weight: 600;
    letter-spacing: 0;
    border: none;
    padding: 0;
    border-radius: 0;
    background: transparent;
  }
  .v7-cluster-page .cta-btn {
    display: block;
    background: #2d6a4f;
    color: #fff;
    text-decoration: none;
    padding: 18px 24px;
    border-radius: 8px;
    font-size: 17px;
    font-weight: 700;
    text-align: center;
    width: 100%;
    min-height: 56px;
    line-height: 1.2;
    margin-bottom: 14px;
    margin-top: 18px;
    transition: background 0.2s;
    letter-spacing: 0.2px;
    -webkit-tap-highlight-color: rgba(45, 106, 79, 0.2);
  }
  .v7-cluster-page .cta-btn:hover {
    background: #245a42;
  }
  /* Post-button block: reverted to previous v7 treatment */
  .v7-cluster-page .quality-line {
    font-size: 12.5px;
    color: #444;
    font-weight: 500;
    line-height: 1.45;
    padding: 0 10px 14px;
    text-align: center;
    letter-spacing: 0.1px;
  }
  .v7-cluster-page .quality-line strong {
    color: #0d3b2e;
    font-weight: 700;
  }
  .v7-cluster-page .trust-badges {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 6px 10px;
    margin-bottom: 16px;
    font-size: 11px;
    color: #666;
    letter-spacing: 0.6px;
    text-transform: uppercase;
    font-weight: 500;
    background: transparent;
    padding: 0;
    border-radius: 0;
  }
  .v7-cluster-page .trust-badges span {
    background: transparent;
    padding: 0;
    border-radius: 0;
    white-space: nowrap;
  }
  .v7-cluster-page .trust-badges span::before {
    content: '✓ ';
    color: #2d6a4f;
    font-weight: 700;
  }
  .v7-cluster-page .trust-badges--logos {
    flex-direction: row;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 18px;
    text-transform: none;
    letter-spacing: 0;
    padding: 4px 0 6px;
  }
  .v7-cluster-page .trust-logo {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
  }
  .v7-cluster-page .trust-logo-img,
  .v7-cluster-page .trust-logo-svg svg {
    display: block;
    width: auto;
    height: 48px;
    max-width: 110px;
    object-fit: contain;
  }
  .v7-cluster-page .shipping-line {
    font-size: 14px;
    color: #0d3b2e;
    font-weight: 600;
    padding-top: 12px;
    margin-top: 0;
    border-top: 1px solid #eee;
    text-align: center;
  }
  .v7-cluster-page .shipping-line strong {
    color: #0d3b2e;
    font-weight: 700;
  }

  .v7-cluster-page .disclosure {
    padding: 32px 24px 40px;
    font-size: 12px;
    color: #999;
    font-style: italic;
    line-height: 1.5;
    border-top: 1px solid #eee;
  }

  /* Desktop polish to match v2 */
  @media (min-width: 641px) {
    .v7-cluster-page .offer-card {
      margin: 36px 0;
    }
    .v7-cluster-page .price-new {
      font-size: 34px;
    }
  }
{% endstylesheet %}

{% schema %}
  {
    "name": "Cluster V7 · Styles",
    "settings": []
  }
{% endschema %}