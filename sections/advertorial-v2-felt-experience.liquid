{% for block in section.blocks %}
  {% case block.type %}
    {% when 'paragraph' %}
      <p class="adv2-body-text" {{ block.shopify_attributes }} data-cs-capture>{{ block.settings.text }}</p>
    {% when 'paragraph_bold' %}
      <p class="adv2-body-text" {{ block.shopify_attributes }} data-cs-capture><strong>{{ block.settings.text }}</strong></p>
  {% endcase %}
{% endfor %}

<div class="adv2-section-break"></div>

{% schema %}
{
  "name": "Advertorial V2 Felt Experience",
  "blocks": [
    {
      "type": "paragraph",
      "name": "Paragraph",
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "Paragraph Text"
        }
      ]
    },
    {
      "type": "paragraph_bold",
      "name": "Bold Paragraph",
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "Bold Paragraph Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Advertorial V2 Felt Experience",
      "blocks": [
        { "type": "paragraph", "settings": { "text": "Pagi seperti ini pasti terdengar familier. Lutut terasa kaku, jari tangan pegal, punggung bawah \"protes\" bahkan sebelum sempat duduk tegak. Beberapa menit menunggu di tepi tempat tidur agar sendi bisa digerakkan — sebelum hari dimulai dan aktivitas tidak pernah berhenti." } },
        { "type": "paragraph_bold", "settings": { "text": "Kebanyakan perempuan mengira ini bagian normal dari bertambah usia. Ternyata bukan." } }
      ]
    }
  ]
}
{% endschema %}
