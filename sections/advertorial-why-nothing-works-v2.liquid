<p class="adv-subhead" data-cs-capture>{{ section.settings.subhead }}</p>

<div class="adv-richtext" data-cs-capture>
  {{ section.settings.body_before_quote }}
</div>

{% if section.settings.quote_text != blank %}
  <div class="adv-pull-quote" data-cs-capture>
    {{ section.settings.quote_text }}
    {% if section.settings.quote_attribution != blank %}
      <span class="adv-attribution" data-cs-capture>{{ section.settings.quote_attribution }}</span>
    {% endif %}
  </div>
{% endif %}

{% if section.settings.body_after_quote != blank %}
  <div class="adv-richtext" data-cs-capture>
    {{ section.settings.body_after_quote }}
  </div>
{% endif %}

{% if section.settings.analogy_image != blank %}
  <div class="adv-image" style="margin: {{ section.settings.image_margin }};">
    {{
      section.settings.analogy_image
      | image_url: width: 1280
      | image_tag: loading: 'lazy', alt: section.settings.analogy_image.alt, data-cs-mask: 'false'
    }}
  </div>
{% endif %}

{% if section.settings.body_after_image != blank %}
  <div class="adv-richtext" data-cs-capture>
    {{ section.settings.body_after_image }}
  </div>
{% endif %}

{% if section.settings.show_exit_cta %}
  <div class="adv-cta-block" id="cta-exit">
    <a href="{{ section.settings.cta_url }}?utm_source=kesehatanwanita_blog&utm_medium=advertorial_cta&utm_campaign={{ section.settings.utm_campaign | default: 'menopause_discovery_launch' | url_encode }}&utm_content={{ section.settings.utm_content | default: 'exit-cta-v2' | url_encode }}"
     class="adv-cta-button"
     data-meta-event="Lead"
     data-meta-product-name="{{ section.settings.meta_product_name }}"
     data-meta-content-id="{{ section.settings.meta_content_id }}"
     data-meta-value="{{ section.settings.meta_product_value }}"
     data-meta-currency="{{ shop.currency }}"
     data-meta-category="Blog to Store Conversion"
     data-meta-cta-position="exit-cta"
     id="meta-cta-trigger-exit">
    {{ section.settings.cta_text }}
  </a>
    {% if section.settings.cta_subtext != blank %}
      <div class="adv-cta-sub" data-cs-capture>{{ section.settings.cta_subtext }}</div>
    {% endif %}
    {% if section.blocks.size > 0 %}
      <div class="adv-cta-badges">
        {% for block in section.blocks %}
          <span {{ block.shopify_attributes }} data-cs-capture>{{ block.settings.badge_label }}</span>
        {% endfor %}
      </div>
    {% endif %}
  </div>

  {% if section.settings.after_cta_text != blank %}
    <p class="adv-body-text" style="font-size: 15px; color: #888; text-align: center; margin-top: -8px;" data-cs-capture>{{ section.settings.after_cta_text }}</p>
  {% endif %}
{% endif %}

{% if section.settings.show_section_break %}
  <div class="adv-section-break"></div>
{% endif %}

{% render 'meta-cta-tracking' %}

{% schema %}
{
  "name": "Adv Why Nothing Works v2",
  "settings": [
    {
      "type": "text",
      "id": "subhead",
      "label": "Section Heading",
      "default": "Mengapa memaksakan diri tidak lagi efektif."
    },
    {
      "type": "richtext",
      "id": "body_before_quote",
      "label": "Body (before pull quote)"
    },
    {
      "type": "textarea",
      "id": "quote_text",
      "label": "Pull Quote Text"
    },
    {
      "type": "text",
      "id": "quote_attribution",
      "label": "Quote Attribution"
    },
    {
      "type": "richtext",
      "id": "body_after_quote",
      "label": "Body (after pull quote, before image)"
    },
    {
      "type": "image_picker",
      "id": "analogy_image",
      "label": "Analogy Image"
    },
    {
      "type": "select",
      "id": "image_margin",
      "label": "Image Margin Style",
      "options": [
        { "value": "20px 0", "label": "Symmetric (20px top & bottom)" },
        { "value": "0px 0 20px", "label": "Bottom only (0 top, 20px bottom)" }
      ],
      "default": "20px 0"
    },
    {
      "type": "richtext",
      "id": "body_after_image",
      "label": "Body (after image)"
    },
    {
      "type": "header",
      "content": "Exit CTA"
    },
    {
      "type": "checkbox",
      "id": "show_exit_cta",
      "label": "Show exit CTA",
      "default": true
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA Button URL"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Button Text",
      "default": "Lihat Discovery Pack \u2192"
    },
    {
      "type": "text",
      "id": "cta_subtext",
      "label": "CTA Subtext",
      "default": "Gratis ongkir untuk pembaca artikel ini \u00b7 selama stok tersedia"
    },
    {
      "type": "text",
      "id": "after_cta_text",
      "label": "Text after CTA",
      "default": "Ingin tahu mengapa moringa ini berbeda? Lanjut baca."
    },
    {
      "type": "checkbox",
      "id": "show_section_break",
      "label": "Show section break line",
      "default": true
    },
    {
      "type": "header",
      "content": "UTM Tracking"
    },
    {
      "type": "text",
      "id": "utm_campaign",
      "label": "UTM Campaign",
      "default": "menopause_discovery_launch"
    },
    {
      "type": "text",
      "id": "utm_content",
      "label": "UTM Content",
      "default": "exit-cta-v2"
    },
    {
      "type": "header",
      "content": "Meta Pixel Tracking"
    },
    {
      "type": "text",
      "id": "meta_product_name",
      "label": "Product Name (for Meta)",
      "default": "Discovery Pack"
    },
    {
      "type": "text",
      "id": "meta_product_value",
      "label": "Product Value (for Meta)",
      "default": "999000"
    },
    {
      "type": "text",
      "id": "meta_content_id",
      "label": "Product ID / SKU (for Meta)",
      "default": "9074141200572"
    }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Trust Badge",
      "settings": [
        {
          "type": "text",
          "id": "badge_label",
          "label": "Badge Label",
          "default": "Terdaftar BPOM"
        }
      ]
    }
  ]
}
{% endschema %}
