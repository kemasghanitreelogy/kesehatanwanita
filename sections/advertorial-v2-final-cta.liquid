<div class="adv2-cta-block" id="adv2-cta2">
  <a href="{{ section.settings.cta_url }}?utm_source=kesehatanwanita_blog&utm_medium=advertorial_cta&utm_campaign=menopause_discovery_launch&utm_content=end-article-v2"
   class="adv2-cta-button"
   data-meta-event="Lead"
   data-meta-product-name="{{ section.settings.meta_product_name }}"
   data-meta-content-id="{{ section.settings.meta_content_id }}"
   data-meta-value="{{ section.settings.meta_product_value }}"
   data-meta-currency="{{ shop.currency }}"
   data-meta-category="Menopause Advertorial to Store"
   data-meta-cta-position="end-article"
   data-meta-content-type="product"
   data-meta-page-source="menopause-advertorial"
   id="adv2-meta-cta-trigger-2">
  {{ section.settings.cta_text }}
</a>
  {% if section.settings.cta_subtext != blank %}
    <div class="adv2-cta-sub" data-cs-capture>{{ section.settings.cta_subtext }}</div>
  {% endif %}
  {% if section.blocks.size > 0 %}
    <div class="adv2-trust-badges">
      {% for block in section.blocks %}
        <span {{ block.shopify_attributes }} data-cs-capture>{{ block.settings.badge_label }}</span>
      {% endfor %}
    </div>
  {% endif %}
</div>

{% if section.settings.disclosure_text != blank %}
  <div class="adv2-disclosure" data-cs-capture>
    {{ section.settings.disclosure_text }}
  </div>
{% endif %}

{% comment %} Close the <article> tag opened in advertorial-v2-hook {% endcomment %}
</article>

{% render 'meta-capi-tracking' %}

{% schema %}
{
  "name": "Advertorial V2 Final CTA",
  "settings": [
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA Button URL"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Button Text",
      "default": "Temukan Discovery Pack →"
    },
    {
      "type": "text",
      "id": "cta_subtext",
      "label": "CTA Subtext",
      "default": "Gratis ongkir untuk pembaca artikel ini"
    },
    {
      "type": "textarea",
      "id": "disclosure_text",
      "label": "Editorial Disclosure",
      "default": "Disclosure: Artikel ini memuat rekomendasi produk Treelogy. Penulis melakukan riset independen terhadap brand ini untuk keperluan penulisan artikel ini."
    },
    {
      "type": "header",
      "content": "Meta Pixel / CAPI Tracking"
    },
    {
      "type": "text",
      "id": "meta_product_name",
      "label": "Product Name (for Meta)",
      "default": "The Discovery Pack",
      "info": "Sent as content_name in the Lead event"
    },
    {
      "type": "text",
      "id": "meta_product_value",
      "label": "Product Value (for Meta)",
      "default": "999000",
      "info": "Numeric value sent with the Lead event"
    },
    {
      "type": "text",
      "id": "meta_content_id",
      "label": "Product ID / SKU (for Meta)",
      "default": "9074141200572",
      "info": "Must match the ID used in your Meta Catalog"
    }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Trust Badge",
      "settings": [
        {
          "type": "text",
          "id": "badge_label",
          "label": "Badge Label",
          "default": "Terdaftar di BPOM"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Advertorial V2 Final CTA",
      "blocks": [
        { "type": "badge", "settings": { "badge_label": "Terdaftar di BPOM" } },
        { "type": "badge", "settings": { "badge_label": "Halal" } },
        { "type": "badge", "settings": { "badge_label": "100% Organik" } },
        { "type": "badge", "settings": { "badge_label": "Terverifikasi Lab" } }
      ]
    }
  ]
}
{% endschema %}
