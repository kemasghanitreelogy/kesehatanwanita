<div class="adv2-richtext" data-cs-capture>
  {{ section.settings.body }}
</div>

{% if section.settings.fact_label != blank or section.settings.fact_text != blank %}
  <aside class="adv2-fact-callout" role="note">
    {% if section.settings.fact_label != blank %}
      <span class="label">{{ section.settings.fact_label }}</span>
    {% endif %}
    {% if section.settings.fact_text != blank %}
      {{ section.settings.fact_text }}
    {% endif %}
  </aside>
{% endif %}

{% if section.settings.comparison_image != blank %}
  <figure class="adv2-image">
    {{
      section.settings.comparison_image
      | image_url: width: 1360
      | image_tag: loading: 'lazy', decoding: 'async', alt: section.settings.comparison_image.alt
    }}
  </figure>
{% endif %}

{% if section.settings.body_after_callout != blank %}
  <div class="adv2-richtext" data-cs-capture>
    {{ section.settings.body_after_callout }}
  </div>
{% endif %}

<div class="adv2-section-break"></div>

{% schema %}
{
  "name": "Advertorial V2 Solution",
  "settings": [
    {
      "type": "richtext",
      "id": "body",
      "label": "Main Body",
      "default": "<p>Sebagian besar perempuan mengatasi gejala satu per satu. Krim untuk sendi. Kopi untuk energi. Obat tidur. Kalsium. Kunyit. Tidak ada yang salah — tetapi tidak ada yang cukup.</p>"
    },
    {
      "type": "text",
      "id": "fact_label",
      "label": "Fact Callout Label",
      "default": "Dari analisis nutrisi yang dipublikasikan"
    },
    {
      "type": "richtext",
      "id": "fact_text",
      "label": "Fact Callout Text"
    },
    {
      "type": "image_picker",
      "id": "comparison_image",
      "label": "Comparison / Infographic Image"
    },
    {
      "type": "richtext",
      "id": "body_after_callout",
      "label": "Body After Callout"
    }
  ]
}
{% endschema %}
