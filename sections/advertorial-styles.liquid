{% comment %}
  Shared CSS for all advertorial sections.
  This section renders no visible HTML — it only injects styles.
{% endcomment %}

{% stylesheet %}
  /* ===== ADVERTORIAL — BLOG LAYOUT (MOBILE FIRST) ===== */
  .advertorial-wrapper {
    max-width: 640px;
    width: 100%;
    margin: 0 auto;
    font-family: -apple-system, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    color: #1a1a1a;
    line-height: 1.78;
    -webkit-font-smoothing: antialiased;
  }

  .advertorial-wrapper * {
    max-width: 100%;
    box-sizing: border-box;
  }

  /* Meta header */
  .adv-meta-header {
    padding: 20px 20px 0;
    font-size: 12px;
    color: #888;
    text-transform: uppercase;
    letter-spacing: 0.8px;
    font-weight: 500;
  }

  /* Headline */
  h1.adv-headline {
    font-size: 24px;
    font-weight: 700;
    line-height: 1.35;
    color: #1a1a1a;
    padding: 16px 20px 8px;
    margin: 0;
    text-wrap: pretty;
  }

  /* Deck */
  .adv-deck {
    font-size: 17px;
    color: #555;
    line-height: 1.6;
    padding: 0 20px 12px;
    font-weight: 400;
  }

  /* Byline */
  .adv-byline {
    font-size: 14px;
    color: #888;
    padding: 0 20px 24px;
    line-height: 1.4;
  }
  p.adv-byline {
    text-wrap: pretty;
  }
  .adv-byline strong {
    color: #555;
  }

  /* Body text */
  .adv-body-text {
    font-size: 17px;
    color: #333;
    margin-bottom: 20px;
    line-height: 1.78;
  }
  .adv-body-text strong {
    font-weight: 600;
    color: #1a1a1a;
  }

  /* Section breaks */
  .adv-section-break {
    width: 40px;
    height: 1px;
    background: #ddd;
    margin: 15px auto 32px 0;
    margin-left: var(--page-margin);
  }

  /* Subheads */
  .adv-subhead {
    font-size: 21px;
    font-weight: 700;
    color: #1a1a1a;
    margin-bottom: 16px;
    line-height: 1.35;
    text-wrap: pretty;
  }

  /* Pull quote */
  .adv-pull-quote {
    font-size: 18px;
    font-weight: 600;
    color: #2d6a4f;
    line-height: 1.5;
    padding: 24px 20px;
    margin: 8px 0;
    border-left: 3px solid #2d6a4f;
    background: #f8faf9;
  }
  .adv-pull-quote .adv-attribution {
    font-size: 13px;
    font-weight: 400;
    color: #888;
    margin-top: 8px;
    display: block;
  }

  /* Inline testimonial */
  .adv-inline-quote {
    font-style: italic;
    font-weight: 600;
    color: #555;
    margin-bottom: 8px;
    font-size: 16px;
  }
  .adv-inline-attribution {
    font-size: 13px;
    color: #999;
    margin-bottom: 24px;
  }

  /* Image */
  .adv-image {
    margin: 20px 0;
    line-height: 0;
    padding: 0;
  }
  .adv-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Fact callout */
  .adv-fact-callout {
    background: #f8faf9;
    border-radius: 8px;
    padding: 20px;
    font-size: 15px;
    color: #333;
    line-height: 1.6;
  }
  .adv-fact-callout strong {
    color: #2d6a4f;
    display: block;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 6px;
  }

  /* CTA block */
  .adv-cta-block {
    text-align: center;
    padding: 28px 20px;
    margin: 8px 0;
  }
  .adv-cta-button {
    display: block;
    background: #2d6a4f;
    color: #fff;
    text-decoration: none;
    padding: 18px 24px;
    border-radius: 8px;
    font-size: 17px;
    font-weight: 600;
    letter-spacing: 0.2px;
    text-align: center;
    width: 100%;
    max-width: 400px;
    margin: 0 auto;
    min-height: 56px;
    line-height: 1.2;
    -webkit-tap-highlight-color: rgba(45, 106, 79, 0.2);
  }
  .adv-cta-sub {
    font-size: 14px;
    color: #888;
    margin-top: 10px;
  }
  .adv-cta-badges {
    display: flex;
    justify-content: center;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: 14px;
    font-size: 12px;
    color: #888;
  }
  .adv-cta-badges span {
    background: #f5f5f0;
    padding: 4px 10px;
    border-radius: 4px;
    white-space: nowrap;
  }

  /* Sign-off / disclosure */
  .adv-sign-off {
    padding: 24px 20px;
    font-size: 14px;
    color: #888;
    border-top: 1px solid #eee;
    margin-top: 20px;
  }
  .adv-sign-off strong {
    color: #555;
    display: block;
    margin-bottom: 2px;
  }

  /* Rich text reset inside advertorial */
  .adv-richtext p {
    font-size: 17px;
    color: #333;
    margin-bottom: 20px;
    line-height: 1.78;
  }
  .adv-richtext strong {
    font-weight: 600;
    color: #1a1a1a;
  }

  /* Desktop */
  @media (min-width: 641px) {
    h1.adv-headline { font-size: 28px; }
    .adv-subhead { font-size: 23px; }
    .adv-cta-button { width: auto; min-width: 320px; display: inline-block; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Advertorial Styles",
  "settings": []
}
{% endschema %}
