{% comment %}
  Shared CSS for all advertorial V2 sections.
  This section renders no visible HTML — it only injects the font link
  and styles. @import is avoided as it blocks rendering; <link> is used instead.
{% endcomment %}

{% comment %} Non-render-blocking font load via <link> instead of CSS @import {% endcomment %}
<link rel="preload" href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Source+Sans+Pro:ital,wght@0,300;0,400;0,600;1,400&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'">
<noscript>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Source+Sans+Pro:ital,wght@0,300;0,400;0,600;1,400&display=swap">
</noscript>

{% stylesheet %}
  /* ===== ADVERTORIAL V2 — EDITORIAL LAYOUT (MOBILE FIRST) ===== */

  .advertorial-v2-wrapper {
    max-width: 680px;
    width: 100%;
    margin: 0 auto;
    padding: 0 24px;
    background: #FDFBF7;
    color: #2D2A26;
    font-family: 'Source Sans Pro', 'Helvetica Neue', sans-serif;
    font-size: 17px;
    line-height: 1.75;
    font-weight: 300;
    -webkit-font-smoothing: antialiased;
  }

  .advertorial-v2-wrapper * {
    max-width: 100%;
    box-sizing: border-box;
  }

  /* ─── HEADER NAV ─── */
  .adv2-site-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 0;
    border-bottom: 1px solid #E8E4DC;
  }
  .adv2-site-header .logo {
    font-family: 'Playfair Display', serif;
    font-size: 15px;
    font-weight: 700;
    color: #2D2A26;
    letter-spacing: 0.02em;
  }
  .adv2-hamburger {
    width: 22px;
    height: 16px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    cursor: pointer;
  }
  .adv2-hamburger span {
    display: block;
    width: 100%;
    height: 2px;
    background: #2D2A26;
  }

  /* ─── META HEADER ─── */
  .adv2-meta-header {
    padding: 32px 0 0;
    font-family: 'Source Sans Pro', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #8B8579;
  }

  /* ─── HEADLINE ─── */
  h1.adv2-headline {
    font-family: 'Playfair Display', serif;
    font-size: 24px;
    line-height: 1.3;
    font-weight: 700;
    color: #1A1A1A;
    margin: 16px 0;
    letter-spacing: -0.01em;
    text-wrap: pretty;
  }

  /* ─── DECK ─── */
  .adv2-deck {
    font-family: 'Source Sans Pro', sans-serif;
    font-size: 16px;
    line-height: 1.6;
    color: #6B6560;
    margin-bottom: 20px;
    font-weight: 300;
  }

  /* ─── BYLINE ─── */
  .adv2-byline {
    font-family: 'Source Sans Pro', sans-serif;
    font-size: 13px;
    color: #8B8579;
    padding-bottom: 24px;
    border-bottom: 1px solid #E8E4DC;
  }
  .adv2-byline strong {
    color: #2D2A26;
    font-weight: 600;
  }

  /* ─── IMAGES ─── */
  .adv2-image {
    width: 100%;
    margin: 28px 0;
    border-radius: 2px;
    line-height: 0;
  }
  .adv2-image img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 2px;
  }
  .adv2-image-caption {
    font-size: 12px;
    color: #A09A93;
    margin-top: 8px;
    font-style: italic;
    line-height: 1.5;
  }

  /* ─── BODY TEXT ─── */
  .adv2-body-text {
    padding: 0;
    margin-bottom: 18px;
    color: #3D3A36;
    font-size: 17px;
    line-height: 1.75;
  }
  .adv2-body-text strong {
    font-weight: 600;
    color: #1A1A1A;
  }

  /* Rich text reset */
  .adv2-richtext p {
    margin-bottom: 18px;
    color: #3D3A36;
    font-size: 17px;
    line-height: 1.75;
  }
  .adv2-richtext strong {
    font-weight: 600;
    color: #1A1A1A;
  }
  .adv2-richtext p:last-child {
    margin-bottom: 0;
  }

  /* ─── SUBHEAD ─── */
  .adv2-subhead {
    font-family: 'Playfair Display', serif;
    font-size: 21px;
    font-weight: 700;
    color: #1A1A1A;
    margin: 32px 0 16px;
    line-height: 1.35;
    text-wrap: pretty;
  }

  /* ─── FACT CALLOUT ─── */
  .adv2-fact-callout {
    background: #F5F2EC;
    border-left: 3px solid #7A8B6F;
    padding: 20px 24px;
    margin: 28px 0;
    border-radius: 0 4px 4px 0;
  }
  .adv2-fact-callout p {
    font-family: 'Source Sans Pro', sans-serif;
    font-size: 15px;
    font-weight: 400;
    color: #3D3A36;
    line-height: 1.65;
    margin: 0;
  }
  .adv2-fact-callout .label {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #7A8B6F;
    margin-bottom: 8px;
    display: block;
  }

  /* ─── CTA BLOCK ─── */
  .adv2-cta-block {
    background: #F0EDE6;
    border-radius: 8px;
    padding: 32px 24px;
    margin: 36px 0;
    text-align: center;
  }
  .adv2-cta-button {
    display: inline-block;
    background: #7A8B6F;
    color: #FFFFFF;
    font-family: 'Source Sans Pro', sans-serif;
    font-size: 16px;
    font-weight: 600;
    padding: 14px 36px;
    border-radius: 6px;
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: background 0.2s;
    min-height: 48px;
    line-height: 1.3;
    -webkit-tap-highlight-color: rgba(122, 139, 111, 0.2);
  }
  .adv2-cta-button:hover { background: #6A7B5F; }
  .adv2-cta-sub {
    font-size: 13px;
    color: #8B8579;
    margin-top: 12px;
    line-height: 1.5;
  }
  .adv2-trust-badges {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px;
    margin-top: 16px;
  }
  .adv2-trust-badges span {
    font-family: 'Source Sans Pro', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    color: #7A8B6F;
    background: #FFFFFF;
    border: 1px solid #D4CEBC;
    padding: 5px 12px;
    border-radius: 20px;
    white-space: nowrap;
  }

  /* ─── TESTIMONIALS ─── */
  .adv2-testimonial-block {
    margin: 32px 0;
  }
  .adv2-testimonial {
    border-left: 2px solid #D4CEBC;
    padding: 12px 0 12px 20px;
    margin-bottom: 20px;
  }
  .adv2-testimonial p {
    font-family: 'Source Sans Pro', sans-serif;
    font-size: 15px;
    font-style: italic;
    color: #4A4640;
    line-height: 1.65;
    margin: 0;
  }
  .adv2-testimonial .source {
    font-size: 12px;
    font-style: normal;
    color: #A09A93;
    margin-top: 6px;
  }

  /* ─── DISCLOSURE ─── */
  .adv2-disclosure {
    font-size: 12px;
    color: #B0AAA0;
    font-style: italic;
    line-height: 1.5;
    padding: 24px 0;
    border-top: 1px solid #E8E4DC;
    margin-top: 20px;
  }

  /* ─── SECTION BREAK ─── */
  .adv2-section-break {
    width: 40px;
    height: 1px;
    background: #E8E4DC;
    margin: 32px 0;
  }

  /* ─── DESKTOP ─── */
  @media (min-width: 641px) {
    h1.adv2-headline { font-size: 28px; }
    .adv2-subhead { font-size: 23px; }
    .adv2-cta-button { min-width: 320px; }
  }

  /* ─── MOBILE TWEAKS ─── */
  @media (max-width: 480px) {
    h1.adv2-headline { font-size: 22px; }
    .adv2-subhead { font-size: 19px; }
    .advertorial-v2-wrapper { font-size: 16px; padding: 0 20px; }
    .adv2-cta-block { padding: 28px 20px; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Adv2 Styles",
  "tag": "div",
  "settings": []
}
{% endschema %}
