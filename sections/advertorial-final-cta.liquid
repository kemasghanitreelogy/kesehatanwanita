<div class="adv-richtext" data-cs-capture>
  {{ section.settings.body }}
</div>

<div class="adv-cta-block" id="cta2">
  <a href="{{ section.settings.cta_url }}?utm_source=kesehatanwanita_blog&utm_medium=advertorial_cta&utm_campaign={{ section.settings.utm_campaign | default: 'moringa_discovery_launch' | url_encode }}&utm_content={{ section.settings.utm_content | default: 'end-article' | url_encode }}"
   class="adv-cta-button"
   data-meta-event="Lead"
   data-meta-product-name="{{ section.settings.meta_product_name }}"
   data-meta-content-id="{{ section.settings.meta_content_id }}"
   data-meta-value="{{ section.settings.meta_product_value }}"
   data-meta-currency="{{ shop.currency }}"
   data-meta-category="Blog to Store Conversion"
   data-meta-cta-position="end-article"
   id="meta-cta-trigger-2">
  {{ section.settings.cta_text }}
</a>
  {% if section.settings.cta_subtext != blank %}
    <div class="adv-cta-sub" data-cs-capture>{{ section.settings.cta_subtext }}</div>
  {% endif %}
  {% if section.blocks.size > 0 %}
    <div class="adv-cta-badges">
      {% for block in section.blocks %}
        <span {{ block.shopify_attributes }} data-cs-capture>{{ block.settings.badge_label }}</span>
      {% endfor %}
    </div>
  {% endif %}
</div>

{% if section.settings.disclosure_text != blank %}
  <div class="adv-sign-off" data-cs-capture>
    <em>{{ section.settings.disclosure_text }}</em>
  </div>
{% endif %}

{% render 'meta-cta-tracking' %}

{% schema %}
{
  "name": "Advertorial Final CTA",
  "settings": [
    {
      "type": "richtext",
      "id": "body",
      "label": "Final Close Text",
      "default": "<p>For anyone who scrolled past the link above — Treelogy's Starter Pack includes the capsules, the powder, and the oil. The capsules and powder are the same moringa leaf in two daily formats, so you can try both and keep the one that fits your routine. The oil is for the skin and hair — the outside half of the equation.</p><p>Based on their customer reviews, most women notice the first changes within the first week. And most who start tend to continue — which, given the consistency the body needs to close a nutrient gap, makes biological sense.</p><p>At the time of writing, the Starter Pack is available with free shipping.</p>"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA Button URL"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Button Text",
      "default": "Start the 30-Day Protocol →"
    },
    {
      "type": "text",
      "id": "cta_subtext",
      "label": "CTA Subtext",
      "default": "Free shipping for readers of this article · 30-day protocol"
    },
    {
      "type": "textarea",
      "id": "disclosure_text",
      "label": "Editorial Disclosure",
      "default": "Disclosure: This article includes a recommendation for Treelogy products. The author independently researched the brand for this piece. For more information, visit treelogy.com."
    },
    {
      "type": "header",
      "content": "UTM Tracking"
    },
    {
      "type": "text",
      "id": "utm_campaign",
      "label": "UTM Campaign",
      "default": "moringa_discovery_launch",
      "info": "Identifies which campaign (e.g. moringa_discovery_launch, menopause_discovery_launch)"
    },
    {
      "type": "text",
      "id": "utm_content",
      "label": "UTM Content",
      "default": "end-article",
      "info": "Identifies CTA position & version (e.g. end-article, end-article-v2)"
    },
    {
      "type": "header",
      "content": "Meta Pixel Tracking"
    },
    {
      "type": "text",
      "id": "meta_product_name",
      "label": "Product Name (for Meta)",
      "default": "Discovery Pack",
      "info": "Sent as content_name in the Lead event"
    },
    {
      "type": "text",
      "id": "meta_product_value",
      "label": "Product Value (for Meta)",
      "default": "299000",
      "info": "Numeric value sent with the Lead event"
    },
    {
      "type": "text",
      "id": "meta_content_id",
      "label": "Product ID / SKU (for Meta)",
      "default": "OMC-90-001",
      "info": "Must match the ID used in your Meta Catalog"
    }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Trust Badge",
      "settings": [
        {
          "type": "text",
          "id": "badge_label",
          "label": "Badge Label",
          "default": "BPOM Certified"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Advertorial Final CTA",
      "blocks": [
        { "type": "badge", "settings": { "badge_label": "BPOM Certified" } },
        { "type": "badge", "settings": { "badge_label": "Halal" } },
        { "type": "badge", "settings": { "badge_label": "100% Organic" } },
        { "type": "badge", "settings": { "badge_label": "Lab-Verified" } }
      ]
    }
  ]
}
{% endschema %}
