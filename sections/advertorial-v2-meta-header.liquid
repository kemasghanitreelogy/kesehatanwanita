<div class="adv2-meta-header" data-cs-capture>
  {{ section.settings.category_text }}
</div>

{% schema %}
{
  "name": "Adv2 Meta Header",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "category_text",
      "label": "Category & Read Time",
      "default": "Kesehatan Wanita · Nutrisi · 2 Menit Baca"
    }
  ]
}
{% endschema %}
