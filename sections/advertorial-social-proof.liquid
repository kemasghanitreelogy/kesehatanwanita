<p class="adv-subhead" data-cs-capture>{{ section.settings.subhead }}</p>

<div class="adv-richtext" data-cs-capture>
  {{ section.settings.intro_text }}
</div>

{% for block in section.blocks %}
  {% if forloop.last and section.settings.outro_position == 'before_last' %}
    <div class="adv-richtext" data-cs-capture>
      {{ section.settings.outro_text }}
    </div>
  {% endif %}

  {% if block.settings.bridge_text != blank %}
    <p class="adv-body-text" {{ block.shopify_attributes }} data-cs-capture>{{ block.settings.bridge_text }}</p>
  {% endif %}

  <p class="adv-inline-quote" {{ block.shopify_attributes }} data-cs-capture>"{{ block.settings.quote_text }}"</p>
  <p class="adv-inline-attribution" data-cs-capture>— {{ block.settings.attribution }}</p>
{% endfor %}

{% if section.settings.outro_position == 'after_all' and section.settings.outro_text != blank %}
  <div class="adv-richtext" data-cs-capture>
    {{ section.settings.outro_text }}
  </div>
{% endif %}

{% if section.settings.show_section_break %}
  <div class="adv-section-break"></div>
{% endif %}

{% schema %}
{
  "name": "Advertorial Social Proof",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_section_break",
      "label": "Show section break line",
      "default": true
    },
    {
      "type": "text",
      "id": "subhead",
      "label": "Section Heading",
      "default": "What 4,700+ Treelogy users are reporting."
    },
    {
      "type": "richtext",
      "id": "intro_text",
      "label": "Intro Text",
      "default": "<p>Moringa is not a miracle. But the pattern across Treelogy's customer reviews — thousands of Indonesian women in this exact phase of life — is consistent enough to be worth paying attention to.</p><p>Most report the first shift between Day 3 and Day 7 — joint stiffness easing, sleep going deeper, the morning \"warm-up\" getting shorter. By Day 14, the changes tend to settle into a rhythm.</p>"
    },
    {
      "type": "richtext",
      "id": "outro_text",
      "label": "Outro Text",
      "default": "<p>Not every user responds the same way. Some feel it in 48 hours. Some take two weeks. But the pattern across their reviews is consistent: the body responds when it finally gets what it's been missing.</p>"
    },
    {
      "type": "select",
      "id": "outro_position",
      "label": "Outro Text Position",
      "options": [
        { "value": "before_last", "label": "Before last testimonial" },
        { "value": "after_all", "label": "After all testimonials" }
      ],
      "default": "before_last"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "text",
          "id": "bridge_text",
          "label": "Bridge Text (before quote)",
          "info": "Editorial sentence that introduces this testimonial."
        },
        {
          "type": "textarea",
          "id": "quote_text",
          "label": "Quote Text"
        },
        {
          "type": "text",
          "id": "attribution",
          "label": "Attribution",
          "default": "Treelogy customer review"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Advertorial Social Proof",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "bridge_text": "One reviewer, four days in:",
            "quote_text": "Baru coba 4 hari dan joint pain saya menghilang. Tidur pun nyenyak.",
            "attribution": "Treelogy customer review"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "bridge_text": "Another, ten days in:",
            "quote_text": "Usia 51 tahun. Hari ke 10, badan kembali segar, ngilu tulang sudah hilang. Hot flashes sudah hampir ngga pernah.",
            "attribution": "Treelogy customer review · Tokopedia"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "bridge_text": "According to one repeat customer, the results surprised even her doctor.",
            "quote_text": "Dokter jantung saya sampai kagum sama hasil check-up rutin saya.",
            "attribution": "Treelogy customer review · Tokopedia"
          }
        }
      ]
    }
  ]
}
{% endschema %}
