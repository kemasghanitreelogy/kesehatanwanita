{% comment %}
  ACT 2: Dari dalam + Dari luar — protocol solution with subheads, body text, and review testimonials
{% endcomment %}

{% for block in section.blocks %}
  {% case block.type %}
    {% when 'subhead' %}
      <p class="adv-subhead" {{ block.shopify_attributes }} data-cs-capture>{{ block.settings.text }}</p>
    {% when 'paragraph' %}
      <div class="adv-richtext" {{ block.shopify_attributes }} data-cs-capture>
        {{ block.settings.text }}
      </div>
    {% when 'review' %}
      <div class="adv-review" style="--review-margin-y: {{ block.settings.margin_y | default: '24px' }};" {{ block.shopify_attributes }} data-cs-capture>
        <q>{{ block.settings.quote_text }}</q>
        {% if block.settings.attribution != blank %}
          <cite>{{ block.settings.attribution }}</cite>
        {% endif %}
      </div>
    {% when 'bold_statement' %}
      <p class="adv-body-text" {{ block.shopify_attributes }} data-cs-capture><strong>{{ block.settings.text }}</strong></p>
  {% endcase %}
{% endfor %}

{% if section.settings.show_section_break %}
  <div class="adv-section-break"></div>
{% endif %}

{% schema %}
{
  "name": "Adv Protocol Solution v2",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_section_break",
      "label": "Show section break line",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "subhead",
      "name": "Subheading",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Subheading Text"
        }
      ]
    },
    {
      "type": "paragraph",
      "name": "Rich Text",
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Body Text"
        }
      ]
    },
    {
      "type": "review",
      "name": "Review Quote",
      "settings": [
        {
          "type": "textarea",
          "id": "quote_text",
          "label": "Quote Text"
        },
        {
          "type": "text",
          "id": "attribution",
          "label": "Attribution"
        },
        {
          "type": "text",
          "id": "margin_y",
          "label": "Vertical margin (CSS)",
          "default": "24px"
        }
      ]
    },
    {
      "type": "bold_statement",
      "name": "Bold Statement",
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "Bold Statement Text"
        }
      ]
    }
  ]
}
{% endschema %}
