<p class="adv-subhead" data-cs-capture>
  {{ section.settings.subhead_prefix }}
  {% if section.settings.subhead_highlight != blank %}
    <span style="font-size: 1.15em; color: #2d6a4f;">{{ section.settings.subhead_highlight }}</span>
  {% endif %}
  {{ section.settings.subhead_suffix }}
</p>

{% if section.settings.intro_text != blank %}
  <div class="adv-richtext" data-cs-capture>
    {{ section.settings.intro_text }}
  </div>
{% endif %}

{% for block in section.blocks %}
  {% case block.type %}
    {% when 'timeline_label' %}
      <p class="adv-body-text" {{ block.shopify_attributes }} data-cs-capture><strong>{{ block.settings.text }}</strong></p>
    {% when 'timeline_entry' %}
      <p class="adv-body-text" {{ block.shopify_attributes }} data-cs-capture><strong>{{ block.settings.label }}</strong> {{ block.settings.body }}</p>
    {% when 'paragraph' %}
      <div class="adv-richtext" {{ block.shopify_attributes }} data-cs-capture>
        {{ block.settings.text }}
      </div>
    {% when 'review' %}
      <div class="adv-review" style="--review-margin-y: {{ block.settings.margin_y | default: '24px' }};" {{ block.shopify_attributes }} data-cs-capture>
        <q>{{ block.settings.quote_text }}</q>
        {% if block.settings.attribution != blank %}
          <cite>{{ block.settings.attribution }}</cite>
        {% endif %}
      </div>
    {% when 'pull_quote' %}
      <div class="adv-pull-quote" {{ block.shopify_attributes }} data-cs-capture>
        {{ block.settings.quote_text }}
        {% if block.settings.attribution != blank %}
          <span class="adv-attribution">{{ block.settings.attribution }}</span>
        {% endif %}
      </div>
    {% when 'bridge_text' %}
      <p class="adv-body-text" {{ block.shopify_attributes }} data-cs-capture>{{ block.settings.text }}</p>
  {% endcase %}
{% endfor %}

{% if section.settings.show_section_break %}
  <div class="adv-section-break"></div>
{% endif %}

{% schema %}
{
  "name": "Adv Social Proof v2",
  "settings": [
    {
      "type": "text",
      "id": "subhead_prefix",
      "label": "Subhead (before highlight)",
      "default": "Apa yang dilaporkan"
    },
    {
      "type": "text",
      "id": "subhead_highlight",
      "label": "Subhead Highlight (colored)",
      "default": "4.700+"
    },
    {
      "type": "text",
      "id": "subhead_suffix",
      "label": "Subhead (after highlight)",
      "default": "perempuan selama 30 hari."
    },
    {
      "type": "richtext",
      "id": "intro_text",
      "label": "Intro Text"
    },
    {
      "type": "checkbox",
      "id": "show_section_break",
      "label": "Show section break line",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "timeline_label",
      "name": "Timeline Label",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Label Text (e.g. Hari ke-3–7:)"
        }
      ]
    },
    {
      "type": "timeline_entry",
      "name": "Timeline Entry",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Bold Label (e.g. Hari ke-3–7:)"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Body text (continues after label)"
        }
      ]
    },
    {
      "type": "paragraph",
      "name": "Rich Text",
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Body Text"
        }
      ]
    },
    {
      "type": "review",
      "name": "Review Quote",
      "settings": [
        {
          "type": "textarea",
          "id": "quote_text",
          "label": "Quote Text"
        },
        {
          "type": "text",
          "id": "attribution",
          "label": "Attribution"
        },
        {
          "type": "text",
          "id": "margin_y",
          "label": "Vertical margin (CSS)",
          "default": "24px"
        }
      ]
    },
    {
      "type": "pull_quote",
      "name": "Pull Quote (featured)",
      "settings": [
        {
          "type": "textarea",
          "id": "quote_text",
          "label": "Quote Text"
        },
        {
          "type": "text",
          "id": "attribution",
          "label": "Attribution"
        }
      ]
    },
    {
      "type": "bridge_text",
      "name": "Bridge Text",
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "Bridge Text"
        }
      ]
    }
  ]
}
{% endschema %}
