{% if section.settings.nutrient_image != blank %}
  <div class="adv-image" style="margin: {{ section.settings.image_margin }};">
    {{
      section.settings.nutrient_image
      | image_url: width: 1280
      | image_tag: loading: 'lazy', alt: section.settings.nutrient_image.alt, data-cs-mask: 'false'
    }}
  </div>
{% endif %}

<div class="adv-richtext" data-cs-capture>
  {{ section.settings.body }}
</div>

{% if section.settings.show_section_break %}
  <div class="adv-section-break"></div>
{% endif %}

{% schema %}
{
  "name": "Adv Moringa Nutrients v2",
  "settings": [
    {
      "type": "image_picker",
      "id": "nutrient_image",
      "label": "Nutrient Comparison Image"
    },
    {
      "type": "select",
      "id": "image_margin",
      "label": "Image Margin Style",
      "options": [
        { "value": "20px 0", "label": "Symmetric (20px top & bottom)" },
        { "value": "0px 0 20px", "label": "Bottom only (0 top, 20px bottom)" }
      ],
      "default": "20px 0"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body Text"
    },
    {
      "type": "checkbox",
      "id": "show_section_break",
      "label": "Show section break line",
      "default": true
    }
  ]
}
{% endschema %}
