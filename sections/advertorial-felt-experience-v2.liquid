{% for block in section.blocks %}
  {% case block.type %}
    {% when 'paragraph' %}
      <p class="adv-body-text" {{ block.shopify_attributes }} data-cs-capture>{{ block.settings.text }}</p>
    {% when 'paragraph_rich' %}
      <div class="adv-richtext" {{ block.shopify_attributes }} data-cs-capture>{{ block.settings.rich_text }}</div>
    {% when 'paragraph_bold' %}
      <p class="adv-body-text" {{ block.shopify_attributes }} data-cs-capture><strong>{{ block.settings.text }}</strong></p>
    {% when 'pull_quote' %}
      <div class="adv-pull-quote" {{ block.shopify_attributes }} data-cs-capture>
        {{ block.settings.quote_text }}
        {% if block.settings.attribution != blank %}
          <span class="adv-attribution">{{ block.settings.attribution }}</span>
        {% endif %}
      </div>
  {% endcase %}
{% endfor %}

{% if section.settings.show_section_break %}
  <div class="adv-section-break"></div>
{% endif %}

{% schema %}
{
  "name": "Adv Felt Experience v2",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_section_break",
      "label": "Show section break line",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "paragraph",
      "name": "Paragraph",
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "Paragraph Text"
        }
      ]
    },
    {
      "type": "paragraph_rich",
      "name": "Paragraph (rich)",
      "settings": [
        {
          "type": "richtext",
          "id": "rich_text",
          "label": "Rich Text"
        }
      ]
    },
    {
      "type": "paragraph_bold",
      "name": "Bold Paragraph",
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "Bold Paragraph Text"
        }
      ]
    },
    {
      "type": "pull_quote",
      "name": "Pull Quote",
      "settings": [
        {
          "type": "textarea",
          "id": "quote_text",
          "label": "Quote Text"
        },
        {
          "type": "text",
          "id": "attribution",
          "label": "Attribution"
        }
      ]
    }
  ]
}
{% endschema %}
